generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("TECHNICIAN")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedOrders     WorkOrder[]              @relation("AssignedTo")
  createdOrders      WorkOrder[]              @relation("CreatedBy")
  comments           Comment[]
  photos             Photo[]
  signatures         Signature[]
  checklistItemsDone WorkOrderChecklistItem[]
  usageLogs          AssetUsageLog[]

  // Auditorías
  auditsAsAuditor   Audit[]      @relation("AuditAuditor")
  auditItemsChecked AuditItem[]  @relation("AuditItemChecker")
  capaAssigned      CapaAction[] @relation("CapaAssigned")
  capaCreated       CapaAction[] @relation("CapaCreated")

  @@map("users")
}

model Asset {
  id           String    @id @default(cuid())
  code         String    @unique
  name         String
  description  String?
  location     String
  area         String
  status       String    @default("OPERATIONAL")
  manufacturer String?
  model        String?
  serialNumber String?
  installDate  DateTime?
  currentHours Float?
  currentCycles Float?
  currentKm    Float?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workOrders       WorkOrder[]
  maintenancePlans MaintenancePlan[]
  usageLogs        AssetUsageLog[]

  @@map("assets")
}

model WorkOrder {
  id             String    @id @default(cuid())
  code           String    @unique @default(cuid())
  title          String
  description    String
  type           String
  status         String    @default("PENDING")
  priority       String    @default("MEDIUM")
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  estimatedHours Float?
  actualHours    Float?
  autoGenerated  Boolean   @default(false)
  periodicidad   String?

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id])

  createdById String
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  maintenancePlanId String?
  maintenancePlan   MaintenancePlan? @relation(fields: [maintenancePlanId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments  Comment[]
  photos    Photo[]
  signature Signature?
  checklist WorkOrderChecklist?

  @@map("work_orders")
}

model MaintenancePlan {
  id            String   @id @default(cuid())
  name          String
  description   String?
  type          String   @default("PREVENTIVE")
  triggerType   String   @default("TIME")
  frequency     Int?
  frequencyUnit String?
  usageThreshold Float?
  usageUnit     String?
  nextDue       DateTime?
  lastGenerated DateTime?
  active        Boolean  @default(true)

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  checklistTemplateId String?
  checklistTemplate   ChecklistTemplate? @relation(fields: [checklistTemplateId], references: [id])

  workOrders WorkOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("maintenance_plans")
}

model ChecklistTemplate {
  id          String @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  items           ChecklistTemplateItem[]
  maintenancePlans MaintenancePlan[]

  @@map("checklist_templates")
}

model ChecklistTemplateItem {
  id          String  @id @default(cuid())
  order       Int
  description String
  required    Boolean @default(false)

  templateId String
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("checklist_template_items")
}

model WorkOrderChecklist {
  id          String    @id @default(cuid())
  completedAt DateTime?

  workOrderId String    @unique
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  items WorkOrderChecklistItem[]

  @@map("work_order_checklists")
}

model WorkOrderChecklistItem {
  id          String    @id @default(cuid())
  order       Int
  description String
  required    Boolean   @default(false)
  checked     Boolean   @default(false)
  checkedAt   DateTime?
  notes       String?

  checklistId String
  checklist   WorkOrderChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  checkedById String?
  checkedBy   User?   @relation(fields: [checkedById], references: [id])

  @@map("work_order_checklist_items")
}

model Photo {
  id           String @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  phase        String

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())

  @@map("photos")
}

model Signature {
  id         String   @id @default(cuid())
  data       String
  signerName String
  signedAt   DateTime @default(now())

  workOrderId String    @unique
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  signedById String
  signedBy   User   @relation(fields: [signedById], references: [id])

  @@map("signatures")
}

model AssetUsageLog {
  id       String   @id @default(cuid())
  value    Float
  unit     String
  loggedAt DateTime @default(now())
  notes    String?

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  loggedById String
  loggedBy   User   @relation(fields: [loggedById], references: [id])

  @@map("asset_usage_logs")
}

model Area {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("areas")
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// ─── Módulo de Auditorías ────────────────────────────────────────────────────

model AuditTemplate {
  id        String                 @id @default(cuid())
  name      String
  type      String                 // "FIVE_S" | "PROCESS"
  isDefault Boolean                @default(false)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  sections  AuditTemplateSection[]
  audits    Audit[]

  @@map("audit_templates")
}

model AuditTemplateSection {
  id         String              @id @default(cuid())
  order      Int
  name       String
  isBehavior Boolean             @default(false)
  weight     Float               @default(1.0)

  templateId String
  template   AuditTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  items      AuditTemplateItem[]

  @@map("audit_template_sections")
}

model AuditTemplateItem {
  id          String               @id @default(cuid())
  order       Int
  description String
  weight      Float                @default(1.0)

  sectionId String
  section   AuditTemplateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("audit_template_items")
}

model Audit {
  id          String    @id @default(cuid())
  code        String    @unique
  title       String
  type        String    // "FIVE_S" | "PROCESS"
  status      String    @default("DRAFT") // DRAFT | IN_PROGRESS | COMPLETED | CLOSED
  area        String
  score       Float?
  notes       String?
  scheduledAt DateTime
  startedAt   DateTime?
  completedAt DateTime?

  auditorId  String
  auditor    User           @relation("AuditAuditor", fields: [auditorId], references: [id])
  templateId String?
  template   AuditTemplate? @relation(fields: [templateId], references: [id])

  sections    AuditSection[]
  capaActions CapaAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("audits")
}

model AuditSection {
  id         String      @id @default(cuid())
  order      Int
  name       String
  isBehavior Boolean     @default(false)
  weight     Float       @default(1.0)

  auditId String
  audit   Audit      @relation(fields: [auditId], references: [id], onDelete: Cascade)
  items   AuditItem[]

  @@map("audit_sections")
}

model AuditItem {
  id          String    @id @default(cuid())
  order       Int
  description String
  weight      Float     @default(1.0)
  result      String?   // "PASS" | "FAIL" | "NA"
  notes       String?
  checkedAt   DateTime?

  sectionId   String
  section     AuditSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  checkedById String?
  checkedBy   User?        @relation("AuditItemChecker", fields: [checkedById], references: [id])

  capaActions CapaAction[]

  @@map("audit_items")
}

model CapaAction {
  id           String    @id @default(cuid())
  code         String    @unique
  type         String    // "CORRECTIVE" | "PREVENTIVE"
  description  String
  rootCause    String?
  severity     String    @default("MINOR") // CRITICAL | MAJOR | MINOR | OBSERVATION
  status       String    @default("OPEN")  // OPEN | IN_PROGRESS | PENDING_VERIFICATION | CLOSED
  dueDate      DateTime
  closedAt     DateTime?
  closingNotes String?

  auditId     String
  audit       Audit     @relation(fields: [auditId], references: [id])
  auditItemId String?
  auditItem   AuditItem? @relation(fields: [auditItemId], references: [id])

  assignedToId String
  assignedTo   User   @relation("CapaAssigned", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User   @relation("CapaCreated", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("capa_actions")
}

model Comment {
  id      String @id @default(cuid())
  content String

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())

  @@map("comments")
}
